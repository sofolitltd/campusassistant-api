@baseUrl = http://localhost:8080/api/v1
@apiKey = 12345

# IMPORTANT: Run requests in sequence (1 -> 2 -> 3...)
# If a request fails, the variables below it will not work.

### 1. Universities
# @name createUniversity
POST {{baseUrl}}/universities
Content-Type: application/json
X-API-Key: {{apiKey}}

{
    "name": "University of Chittagong",
    "acronym": "CU",
    "slug": "university-of-chittagong",
    "established_year": 1966,
    "address": "Chittagong, Bangladesh",
    "about": "<h1>Welcome to CU</h1><p>The largest campus in Bangladesh.</p>",
    "latitude": 22.4716,
    "longitude": 91.7877,
    "website_url": "https://cu.ac.bd"
}

### Capture ID
@universityId = {{createUniversity.response.body.id}}

### Get All Universities
GET {{baseUrl}}/universities
X-API-Key: {{apiKey}}

### Get University by ID
GET {{baseUrl}}/universities/{{universityId}}
X-API-Key: {{apiKey}}


### 2. Departments
# @name createDepartment
POST {{baseUrl}}/departments
Content-Type: application/json
X-API-Key: {{apiKey}}

{
    "name": "Department of Psychology",
    "acronym": "PSY",
    "slug": "psychology",
    "university_id": "{{universityId}}",
    "established_year": 2005,
    "about": "Exploring the human mind.",
    "semesters": 8
}

### Capture ID
@departmentId = {{createDepartment.response.body.id}}

### 3. Semesters
# @name createSemester
POST {{baseUrl}}/semesters
Content-Type: application/json
X-API-Key: {{apiKey}}

{
    "name": "1st Year 1st Semester",
